{
  "entities": {
    "Question": {
      "title": "Question",
      "description": "A global question in the database",
      "type": "object",
      "properties": {
        "displayId": { "type": "integer" },
        "text": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "correctOptionIndex": { "type": "integer" },
        "classification": { "type": "string" },
        "topic": { "type": "string" },
        "userId": { "type": "string", "description": "The user who created this question (optional, null for global questions)" },
        "createdAt": { "type": "string", "format": "date-time" },
        "sourcePdf": { "type": "string" },
        "mnemonics": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["text", "options", "correctOptionIndex", "classification", "topic"]
    },
    "User": {
      "title": "User",
      "description": "A user of the platform",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "student"] },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "permissions": { "type": "array", "items": { "type": "string" } },
        "gender": { "type": "string", "enum": ["Opositor", "Opositora"] },
        "oppositionType": { "type": "string" },
        "onboardingCompleted": { "type": "boolean" },
        "sessionId": { "type": "string", "description": "Current active session ID for multi-account prevention" }
      },
      "required": ["email", "role"]
    },
    "SavedPrompt": {
      "title": "SavedPrompt",
      "description": "Metadata for a saved prompt",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "prompt": { "type": "string" },
        "userId": { "type": "string" },
        "isAdminPrompt": { "type": "boolean" },
        "topic": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "prompt", "userId"]
    },
    "PromptAccess": {
      "title": "PromptAccess",
      "description": "Access grant for an admin prompt to a specific user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "promptId": { "type": "string" },
        "granted": { "type": "boolean" },
        "grantedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "promptId", "granted"]
    },
    "PromptContent": {
      "title": "PromptContent",
      "description": "The actual text content of a prompt",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "userId": { "type": "string" },
        "isAdminPrompt": { "type": "boolean" }
      },
      "required": ["content", "userId"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback and suggestions",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["improvement", "complaint", "other"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "reviewed"] }
      },
      "required": ["userId", "userEmail", "userName", "message", "type", "createdAt", "status"]
    },
    "UserProgress": {
      "title": "UserProgress",
      "description": "Individual progress for a question",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "questionId": { "type": "string" },
        "hits": { "type": "integer" },
        "misses": { "type": "integer" },
        "masteryLevel": { "type": "integer" },
        "nextReviewDate": { "type": "string", "format": "date-time" },
        "reps": { "type": "integer" },
        "easeFactor": { "type": "number" },
        "interval": { "type": "integer" },
        "lastSeen": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "questionId"]
    },
    "ReviewHistory": {
      "title": "ReviewHistory",
      "description": "History of a single question review",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "questionId": { "type": "string" },
        "isCorrect": { "type": "boolean" },
        "reviewedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "questionId", "isCorrect", "reviewedAt"]
    },
    "TestSession": {
      "title": "TestSession",
      "description": "A completed test session",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "completedAt": { "type": "string", "format": "date-time" },
        "topics": { "type": "array", "items": { "type": "string" } },
        "totalQuestions": { "type": "integer" },
        "correctCount": { "type": "integer" },
        "incorrectCount": { "type": "integer" },
        "score": { "type": "number" }
      },
      "required": ["userId", "completedAt", "totalQuestions", "correctCount", "incorrectCount", "score"]
    },
    "TopicResource": {
      "title": "TopicResource",
      "description": "A resource (PDF) associated with a topic",
      "type": "object",
      "properties": {
        "topic": { "type": "string" },
        "classification": { "type": "string" },
        "fileName": { "type": "string" },
        "extractedText": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["topic", "classification", "fileName"]
    }
  },
  "firestore": {
    "/questions/{questionId}": {
      "schema": "Question",
      "description": "Global questions"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/user_progress/{progressId}": {
      "schema": "UserProgress",
      "description": "Individual user progress for questions"
    },
    "/review_history/{historyId}": {
      "schema": "ReviewHistory",
      "description": "History of reviews"
    },
    "/test_sessions/{sessionId}": {
      "schema": "TestSession",
      "description": "Test session history"
    },
    "/topic_resources/{resourceId}": {
      "schema": "TopicResource",
      "description": "Topic resources"
    },
    "/feedback/{feedbackId}": {
      "schema": "Feedback",
      "description": "User feedback"
    },
    "/metadata/counters": {
      "schema": {
        "type": "object",
        "properties": {
          "questionDisplayId": { "type": "integer" }
        }
      },
      "description": "Global counters"
    }
  }
}
